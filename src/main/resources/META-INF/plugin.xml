<idea-plugin>
    <id>dev.skrety.sf-toolkit</id>
    <name>SF Toolkit</name>
    <vendor>Skrety</vendor>
    <description><![CDATA[
        Salesforce toolkit for JetBrains IDEs: org management, retrieve / deploy /
        compare, SOQL queries, anonymous Apex and test runs — all driven through
        the Salesforce CLI (<code>sf</code>), which owns authentication.
        <br/><br/>
        Apex/SOQL syntax highlighting uses the BSD-licensed TextMate grammars from
        the forcedotcom/apex-tmLanguage project.
    ]]></description>

    <!-- Platform-only dependency: runs in IDEA CE/Ultimate, WebStorm, PyCharm, etc. -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Apex/SOQL highlighting — active when the bundled TextMate plugin is enabled. -->
    <depends optional="true" config-file="sf-toolkit-textmate.xml">org.jetbrains.plugins.textmate</depends>
    <!-- Apex Language Server — active when the free LSP4IJ plugin is installed. -->
    <depends optional="true" config-file="sf-toolkit-lsp4ij.xml">com.redhat.devtools.lsp4ij</depends>

    <applicationListeners>
        <listener class="dev.skrety.sftoolkit.SfAppHealth"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="SF Toolkit" displayType="BALLOON"/>
        <applicationConfigurable parentId="tools" id="dev.skrety.sftoolkit.settings"
                                 displayName="SF Toolkit"
                                 instance="dev.skrety.sftoolkit.SfSettingsConfigurable"/>
        <statusBarWidgetFactory id="SfToolkitOrg"
                                implementation="dev.skrety.sftoolkit.OrgStatusBarWidgetFactory"/>
        <toolWindow id="SF Log" anchor="bottom" secondary="true"
                    icon="AllIcons.Toolwindows.ToolWindowMessages"
                    factoryClass="dev.skrety.sftoolkit.SfLogToolWindowFactory"/>
        <toolWindow id="SOQL" anchor="bottom" canCloseContents="true"
                    icon="AllIcons.Nodes.DataTables"
                    factoryClass="dev.skrety.sftoolkit.soql.SoqlToolWindowFactory"/>
        <toolWindow id="SF Toolkit" anchor="left"
                    icon="/icons/sfCloud.svg"
                    factoryClass="dev.skrety.sftoolkit.ui.HubToolWindowFactory"/>
        <toolWindow id="SF Metadata" anchor="left" secondary="true"
                    icon="/icons/sfMetadata.svg"
                    factoryClass="dev.skrety.sftoolkit.metadata.MetadataToolWindowFactory"/>
        <toolWindow id="Anonymous Apex" anchor="bottom" secondary="true" canCloseContents="true"
                    icon="AllIcons.Actions.Execute"
                    factoryClass="dev.skrety.sftoolkit.apex.ApexToolWindowFactory"/>
        <toolWindow id="Apex Logs" anchor="bottom" secondary="true"
                    icon="AllIcons.Debugger.Console"
                    factoryClass="dev.skrety.sftoolkit.apex.ApexLogsToolWindowFactory"/>
        <postStartupActivity implementation="dev.skrety.sftoolkit.SfStartup"/>
        <customScopesProvider implementation="dev.skrety.sftoolkit.SfSearchScopes"/>
        <!-- Icons + Settings→File Types entries; highlighting delegated to TextMate
             (see sf-toolkit-textmate.xml). -->
        <fileType name="Apex" implementationClass="dev.skrety.sftoolkit.filetypes.ApexFileType"
                  fieldName="INSTANCE" extensions="cls;trigger;apex"/>
        <fileType name="SOQL" implementationClass="dev.skrety.sftoolkit.filetypes.SoqlFileType"
                  fieldName="INSTANCE" extensions="soql"/>
    </extensions>

    <actions>
        <group id="SfToolkit.Tools" text="SF Toolkit" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="SfToolkit.Login" class="dev.skrety.sftoolkit.LoginAction"
                    text="Log In to Salesforce Org…"
                    description="Authenticate a Salesforce org via sf org login web"/>
            <action id="SfToolkit.HealthCheck" class="dev.skrety.sftoolkit.HealthCheckAction"
                    text="Run Health Check"
                    description="Report the status of every SF Toolkit integration"/>
            <action id="SfToolkit.GenerateSObjects"
                    class="dev.skrety.sftoolkit.schema.GenerateSObjectDefinitionsAction"
                    text="Generate Apex sObject Definitions"
                    description="Write faux classes to .sfdx/tools/sobjects so Apex completion knows org fields"/>
        </group>

        <group id="SfToolkit.Context" text="SF Toolkit" popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <action id="SfToolkit.Retrieve" class="dev.skrety.sftoolkit.RetrieveAction"
                    text="Retrieve from Org"
                    description="sf project retrieve start for the selected files"/>
            <action id="SfToolkit.Deploy" class="dev.skrety.sftoolkit.DeployAction"
                    text="Deploy to Org"
                    description="sf project deploy start for the selected files"/>
            <action id="SfToolkit.Validate" class="dev.skrety.sftoolkit.ValidateAction"
                    text="Validate Deploy (Dry Run)"
                    description="sf project deploy start --dry-run for the selected files"/>
            <action id="SfToolkit.Compare" class="dev.skrety.sftoolkit.CompareWithOrgAction"
                    text="Compare with Org"
                    description="Diff the local file against the component body in the org"/>
            <action id="SfToolkit.RunTests" class="dev.skrety.sftoolkit.apex.RunApexTestsAction"
                    text="Run Apex Tests in Class"
                    description="sf apex run test --synchronous for this class"/>
            <action id="SfToolkit.FormatApex" class="dev.skrety.sftoolkit.apex.FormatApexAction"
                    text="Format with Prettier Apex"
                    description="Format the current Apex file via npx prettier-plugin-apex"/>
        </group>
    </actions>
</idea-plugin>
